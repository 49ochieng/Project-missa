{
  "name": "meeting-media-bot",
  "version": "1.0.0",
  "description": "Teams meeting media bot for call joining and real-time transcription",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon -w \"./src/**\" -e ts --exec \"node --inspect=9240 -r ts-node/register ./src/index.ts\"",
    "dev:env": "DOTENV_CONFIG_PATH=.env node -r dotenv/config -r ts-node/register ./src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@azure/identity": "^4.12.0",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "microsoft-cognitiveservices-speech-sdk": "^1.34.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "nodemon": "^3.0.2",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  }
}
