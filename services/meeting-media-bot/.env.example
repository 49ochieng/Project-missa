# =============================================================================
# Meeting Media Bot - Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# ---------------------------------------------------------------------------
# Azure AD App Registration (the bot's identity)
# This must be the SAME app registration used for Project Missa
# Required Graph API permissions (Application):
#   - Calls.JoinGroupCall.All
#   - Calls.AccessMedia.All
#   - OnlineMeetingTranscript.Read.All
# ---------------------------------------------------------------------------
AZURE_TENANT_ID=588cadf4-9902-4465-86c0-8bcf04f4f102
AZURE_CLIENT_ID=0ead46b4-34bd-4050-93fb-f4cd35afbcb6
AZURE_CLIENT_SECRET=<your-client-secret-from-azure-portal>

# Bot registration IDs (same as AZURE_CLIENT_ID for most setups)
BOT_APP_ID=0ead46b4-34bd-4050-93fb-f4cd35afbcb6
BOT_APP_PASSWORD=<your-bot-password>

# ---------------------------------------------------------------------------
# Public URL — REQUIRED for Graph callbacks (call state notifications)
# For local dev: use ngrok or dev tunnels
#   ngrok: ngrok http 4000  →  copy the https URL here
#   Teams Toolkit dev tunnel: copy from .localConfigs after `npm run dev:teamsfx`
# The URL MUST be HTTPS and publicly reachable by Microsoft Graph
# ---------------------------------------------------------------------------
BOT_ENDPOINT=https://YOUR-NGROK-ID.ngrok-free.app

# ---------------------------------------------------------------------------
# Azure Speech Service (for real-time transcription + speaker diarization)
# Create at: Azure Portal → Cognitive Services → Speech Service
# Supported regions: eastus, westus, westeurope, etc.
# ---------------------------------------------------------------------------
AZURE_SPEECH_KEY=<your-azure-speech-key>
AZURE_SPEECH_REGION=eastus

# ---------------------------------------------------------------------------
# Shared secret — must match MEETING_MEDIA_BOT_SHARED_SECRET in Project Missa
# Use any strong random string (e.g. openssl rand -hex 32)
# ---------------------------------------------------------------------------
SHARED_SECRET=dev-secret-change-in-production

# ---------------------------------------------------------------------------
# Project Missa internal API URL
# This is where meeting-media-bot sends transcript chunks back to
# Project Missa runs an internal Express server on port 3980
# ---------------------------------------------------------------------------
PROJECT_MISSA_URL=http://localhost:3980

# ---------------------------------------------------------------------------
# Server port for meeting-media-bot (default: 4000)
# ---------------------------------------------------------------------------
PORT=4000

# ---------------------------------------------------------------------------
# Auto-join configuration (Tier 2 — Calendar-based auto-join)
# Requires Calendars.Read.All Application permission on the Azure AD app.
# To add: Azure Portal → App registrations → {AZURE_CLIENT_ID} → API permissions → Add
#
# Set EITHER email OR object ID (object ID is faster — no extra API call to resolve)
# To find Object ID: Azure Portal → Users → {user} → Object ID
# ---------------------------------------------------------------------------
AUTO_JOIN_USER_EMAIL=edgar.mcochieng@yourdomain.com
AUTO_JOIN_USER_OBJECT_ID=
CALENDAR_POLL_INTERVAL_MS=60000
