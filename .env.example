# ============================================================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================================
# Copy this file to .env.local or .env.{environment} and fill in your values.
# SECRET values should NOT be committed to source control.
# ============================================================================

# ─── AZURE AUTHENTICATION ───────────────────────────────────────────────────
# Required for Microsoft Graph API calls and Azure services
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
SECRET_AZURE_CLIENT_SECRET=your-client-secret

# ─── BOT CONFIGURATION ──────────────────────────────────────────────────────
# Azure Bot Service registration
BOT_APP_ID=your-bot-app-id
SECRET_BOT_APP_PASSWORD=your-bot-app-password

# Public endpoint for the bot (used for callback URLs)
# For local development, use your dev tunnel URL
BOT_ENDPOINT=https://your-bot-domain.azurewebsites.net
PUBLIC_BASE_URL=https://your-bot-domain.azurewebsites.net

# ─── MICROSOFT GRAPH ────────────────────────────────────────────────────────
GRAPH_BASE_URL=https://graph.microsoft.com

# ─── AZURE OPENAI ───────────────────────────────────────────────────────────
# Azure OpenAI Service configuration
AZURE_OPENAI_ENDPOINT=https://your-openai.openai.azure.com
SECRET_AZURE_OPENAI_API_KEY=your-openai-api-key
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# ─── AZURE SPEECH SERVICE ───────────────────────────────────────────────────
# Required for real-time meeting transcription
SECRET_AZURE_SPEECH_KEY=your-speech-service-key
AZURE_SPEECH_REGION=eastus

# ─── DATABASE CONFIGURATION ─────────────────────────────────────────────────
# Option 1: Use SQLite (default for local development)
SQLITE_PATH=./src/storage/conversations.db

# Option 2: Use SQL Server (for production)
# DATABASE_CONNECTION_STRING=Server=your-server.database.windows.net;Database=your-db;User Id=your-user;Password=your-password;Encrypt=true
# Or use individual connection parameters:
# SQL_SERVER=your-server.database.windows.net
# SQL_DATABASE=your-database
# SQL_USERNAME=your-username
# SQL_PASSWORD=your-password

# ─── MEETING MEDIA BOT (Internal Service) ───────────────────────────────────
# URL of the meeting-media-bot service for call joining and media handling
MEETING_MEDIA_BOT_URL=http://localhost:3980

# Shared secret for authenticating requests between services
# Generate a strong random string: openssl rand -base64 32
SECRET_MEETING_MEDIA_BOT_SHARED_SECRET=your-shared-secret-here

# ─── TEAMS TOOLKIT VARIABLES (Auto-populated) ───────────────────────────────
# These are typically set by Teams Toolkit during local debugging
# TEAMS_APP_ID=auto-populated
# BOT_ID=auto-populated
# BOT_DOMAIN=auto-populated
# APP_NAME_SUFFIX=auto-populated

# ─── DEVELOPMENT FLAGS ──────────────────────────────────────────────────────
# Set to "1" when running on Azure (uses MSSQL instead of SQLite)
# RUNNING_ON_AZURE=0

# Bot type for authentication (UserAssignedMsi for Azure, leave empty for local)
# BOT_TYPE=UserAssignedMsi
# CLIENT_ID=your-managed-identity-client-id
