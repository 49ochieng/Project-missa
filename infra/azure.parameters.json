{
  "$schema": "https://schema.management.azure.com/schemas/2015-01-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "resourceBaseName": {
      "value": "bot${{RESOURCE_SUFFIX}}"
    },
    "webAppSKU": {
      "value": "B1"
    },
    "botDisplayName": {
      "value": "Project missa"
    },
    "AOAI_ENDPOINT": {
      "value": "${{AZURE_OPENAI_ENDPOINT}}"
    },
    "AOAI_API_KEY": {
      "value": "${{SECRET_AZURE_OPENAI_API_KEY}}"
    },
    "AOAI_MODEL": {
      "value": "${{AZURE_OPENAI_DEPLOYMENT_NAME}}"
    },
    "location": {
      "value": "westus2"
    },
    "sqlServer": {
      "value": "${{SQL_SERVER}}"
    },
    "sqlDatabase": {
      "value": "${{SQL_DATABASE}}"
    },
    "sqlUsername": {
      "value": "${{SQL_USERNAME}}"
    },
    "sqlPassword": {
      "value": "${{SQL_PASSWORD}}"
    },
    "meetingMediaBotSecret": {
      "value": "${{SECRET_MEETING_MEDIA_BOT_SECRET}}"
    },
    "meetingBotTenantId": {
      "value": "${{AZURE_TENANT_ID}}"
    },
    "meetingBotClientId": {
      "value": "${{SECRET_MEETING_BOT_CLIENT_ID}}"
    },
    "meetingBotClientSecret": {
      "value": "${{SECRET_MEETING_BOT_CLIENT_SECRET}}"
    },
    "meetingBotAppId": {
      "value": "${{BOT_APP_ID}}"
    },
    "azureSpeechKey": {
      "value": "${{SECRET_AZURE_SPEECH_KEY}}"
    },
    "azureSpeechRegion": {
      "value": "southcentralus"
    }
  }
}
