{
    "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.24/MicrosoftTeams.schema.json",
    "manifestVersion": "1.24",
    "version": "1.0.13",
    "id": "${{TEAMS_APP_ID}}",
    "developer": {
        "name": "Armely",
        "websiteUrl": "https://www.armely.com",
        "privacyUrl": "https://www.armely.com/privacy",
        "termsOfUseUrl": "https://www.armely.com/terms"
    },
    "icons": {
        "color": "color.png",
        "outline": "outline.png"
    },
    "name": {
        "short": "Missa${{APP_NAME_SUFFIX}}",
        "full": "Missa - Your Intelligent Meeting Assistant"
    },
    "description": {
        "short": "AI-powered meeting intelligence assistant",
        "full": "Missa is an intelligent AI meeting assistant that summarizes conversations, captures action items, and helps teams collaborate more effectively."
    },
    "accentColor": "#6264A7",
    "bots": [
        {
            "botId": "${{BOT_ID}}",
            "scopes": [
                "team",
                "groupChat",
                "personal"
            ],
            "supportsFiles": false,
            "isNotificationOnly": false,
            "supportsCalling": false,
            "supportsVideo": false,
            "commandLists": [
                {
                    "scopes": [
                        "personal",
                        "groupChat",
                        "team"
                    ],
                    "commands": [
                        {
                            "title": "summarize",
                            "description": "Summarize recent conversation or meeting"
                        },
                        {
                            "title": "action items",
                            "description": "Find and list action items from conversation"
                        }
                    ]
                }
            ]
        }
    ],
    "composeExtensions": [],
    "configurableTabs": [],
    "staticTabs": [],
    "permissions": [
        "identity",
        "messageTeamMembers"
    ],
    "validDomains": []
}
